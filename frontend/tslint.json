{
  "extends": "tslint:recommended",
  "rules": {
    "quotemark": [true, "single"],
    "semicolon": [true, "always"],
    "trailing-comma": false,
    "object-literal-sort-keys": false,
    "member-access": false,
    "ordered-imports": false,
    "interface-name": false,
    "max-line-length": false,
    "arrow-parens": false,
    "triple-equals": false
  }
}
